@misc{Malinowska2025d,
  title = {Global Geo-Hazard Risk Assessment of Long-Span Bridges Enhanced with {{InSAR}} Availability - Research Data},
  author = {Malinowska, Dominika and Milillo, Pietro and Reale, Cormac and Blenkinsopp, Chris and Giardina, Giorgia},
  year = 2025,
  month = jul,
  publisher = {Zenodo},
  doi = {10.5281/ZENODO.15797029},
  urldate = {2026-03-16},
  altmetric = {true},
  dimensions = {true},
  abstract = {Global Geo-hazard Risk Assessment of Long-Span Bridges Enhanced with InSAR Availability - Research Data Description This dataset contains processed geospatial data, risk assessment results, and visualisation materials supporting the research paper "Global geo-hazard risk assessment of long-span bridges enhanced with InSAR availability", published in Nature Communications, DOI: 10.1038/s41467-025-64260-x. Contents Hazard Data (hazard/): Normalised geotiff rasters for landslide susceptibility and ground subsidence hazards. The hazard data was originally published by Herrera-Garc\'ia, G. et al, while the landslide dataset was created by Redshaw, P. \& Bottomley, J.. This dataset only contains normalised versions of the aforementioned datasets. Herrera-Garc\'ia, G. et al. Mapping the global threat of land subsidence. Science 371, 34--36 (2021). DOI:~10.1126/science.abb8549 Redshaw, P. \& Bottomley, J. The Global Landslide Hazard Map: Final Project Report. Tech. Rep., The World Bank (2020).~ ~ Persistent Scatterer Predictions (predicted\_PS/): Machine learning-generated MT-InSAR PS availability predictions by continent (7 continental regions). Generated using methodology proposed by Malinowska, D., Milillo, P., Briggs, K., Reale, C., and Giardina, G. Malinowska, D., Milillo, P., Briggs, K., Reale, C. \& Giardina, G. Coherence-based Prediction of Multi-Temporal InSAR Measurement Availability for Infrastructure Monitoring. IEEE J. Sel. Top. Appl. Earth Obs. Remote. Sens. 1--22 (2024). DOI: 10.1109/JSTARS.2024.3449688 ~ Risk Assessment Results (risk\_assessment/): Bridge risk analysis outputs with multiple monitoring factor thresholds (1.15-1.55), provided in both CSV and pickle formats ~ Satellite Data Availability (snt\_availability/): Sentinel-1 coverage shapefiles for current conditions and pre-failure scenarios. Those were derived using Sentinel acquisition plans ~ Visualisation Data (plots/): Source data (CSV) for all manuscript figures and supplementary materials Generated plot images (JPG format) World administrative boundaries for mapping Data Formats Raster data: GeoTIFF (.tif) Vector data: ESRI Shapefiles (.shp, .dbf, .prj, .shx) Tabular data: CSV and Python pickle (.pkl) files Images: JPEG (.jpg) Usage Data can be processed using the companion code repository. Risk assessment results are ready for analysis, while source data enables reproduction of all manuscript figures. Geospatial data requires GIS software or Python packages (rasterio, geopandas) for processing. Related Publication Dataset supports: "Global geo-hazard risk assessment of long-span bridges enhanced with InSAR availability", published in Nature Communications, DOI: 10.1038/s41467-025-64260-x. Code repository:~ bridge-risk-assessment-insar; archived on Zenodo: 10.5281/zenodo.15831783},
  copyright = {Creative Commons Attribution 4.0 International}
}

@misc{Malinowska2026,
  title = {Risk Assessment of Bridges Affected by Subsidence and Landslides Using Ground and Spaceborne Monitoring: A Global Study},
  shorttitle = {Risk Assessment of Bridges Affected by Subsidence and Landslides Using Ground and Spaceborne Monitoring},
  author = {Malinowska, Dominika and Milillo, Pietro and Reale, Cormac and Blenkinsopp, Chris and Giardina, Giorgia},
  year = 2026,
  month = may,
  doi = {10.5194/egusphere-egu26-13903},
  altmetric = {true},
  dimensions = {true},
  abstract = {Bridges are a core element of transport systems, enabling connectivity and supporting access to employment, education, medical care and emergency response. Despite this central role, they are also among the most fragile assets in these networks, as they are frequently exposed to natural hazards whose occurrence and intensity are expected to grow under changing climatic conditions. Although assessing geo-hazard risk to bridges is essential for meeting the United Nations Sustainable Development Goals, current risk evaluation practices rarely account for how structural vulnerability evolves over time. In particular, they overlook the contribution of continuous monitoring technologies such as Structural Health Monitoring (SHM) sensors and Interferometric Synthetic Aperture radar (InSAR), which can provide ongoing information on bridge condition. Furthermore, while SHM installations remain limited, the global capacity of InSAR to complement these systems for bridge surveillance has not yet been systematically quantified.This study introduces a new framework for assessing bridge geo-hazard risk worldwide that explicitly incorporates the availability of both ground-based SHM and satellite-derived monitoring. The assessment integrates subsidence and landslide hazards with measures of exposure and structural vulnerability.A global analysis of satellite monitoring coverage reveals a substantial shortfall in current observation capability. Only a small fraction of long-span bridges is equipped with SHM systems, whereas InSAR observations from Sentinel-1 could potentially cover a far larger share of the global bridge inventory. Expanding the use of this spaceborne data could therefore lower overall geo-hazard risk and reduce the number of bridges categorised as high risk. Many of the structures that would remain in the high-risk category are also well-suited to satellite-based monitoring, underlining the value of InSAR for improving safety and resilience, particularly in low-income and resource-constrained regions. By linking risk with monitoring suitability, the proposed framework highlights that the presence of SHM and InSAR sensors enables more dynamic and time-sensitive risk evaluation, providing practical guidance for prioritising satellite monitoring, SHM deployment, and on-site inspections within a risk-informed decision-making process.}
}
